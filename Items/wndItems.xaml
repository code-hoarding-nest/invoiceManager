<Window x:Class="GroupFinal3280.wndItems"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GroupFinal3280"
        mc:Ignorable="d"
        Title="Items" Height="450" Width="800" Background="#FFE6A7" Foreground="#FF371D0D">
    <!--#region Main Grid-->
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        
        
        <!--#region Nav Button-->

        <Button x:Name="cmdReturntoMain" Content="Return to Main" Grid.Row="0"  HorizontalAlignment="Left" VerticalAlignment="Center"  Click="cmdReturntoMain_Click" Style="{DynamicResource ButtonLight}" />
        
        <!--#endregion Nav Button-->
        
        
        <!--#region Item delete, edit, and add Buttons -->
        
        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            <Button Content="Delete" Name="cmdDelete" Click="cmdDelete_Click"  Style="{DynamicResource ButtonLight}"/>
            <Button Content="Edit Items" Name="cmdEdit" Click="cmdEdit_Click"   Style="{DynamicResource ButtonLight}"/>
            <Button Content="Save Items" Name="cmdSave"   Click="cmdSave_Click" Visibility="Collapsed" Style="{DynamicResource ButtonLight}"/>
            <Button Content="Add Item" Name="cmdAdd" Click="cmdAdd_Click"  Style="{DynamicResource ButtonLight}"/>
        </StackPanel>
        
        <!--#endregion Item delete, edit, and add Buttons -->

        
        <!--#region Item description and cost lbls and txt -->
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Label Content="Code: " Margin="25,0,0,0"/>
            <ComboBox Name="cbCode" Style="{DynamicResource ComboBoxStyle1}" SelectionChanged="cbCode_SelectionChanged"/> 
            <Label Content="Description: " Margin="25,0,0,0"/>
            <TextBox Name="txtDesc" MinWidth="150" Margin="0,0,30,0" Opacity=".8"/>
                <Label Content="Cost: " Margin="30, 0, 0,0"/>
            <TextBox Name="txtCost" MinWidth="150" PreviewKeyDown="txtCost_PreviewKeyDown" Opacity=".8"/>
            </StackPanel>
        
        <!--#endregion Item description and cost lbls and txt -->

        
        <!--#region datagrid for Items -->

        <DataGrid Grid.Row="3" Name="dgItems" Style="{DynamicResource DataGridStyle1}" SelectedCellsChanged="dgItems_SelectedCellsChanged">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Padding" Value="5"/>
                    <Setter Property="Background" Value="#FFEBB586"/>
                    <Setter Property="Foreground" Value="#FF432818"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!--#endregion datagrid for Items -->
        
        
    </Grid>
    <!--#endregion Main Grid-->
</Window>
